font-family = "MonoLisa Variable"
#font-feature = +ss02
font-size = 13

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 5s

#30x the default limit of 10000000
scrollback-limit = 300000000

mouse-hide-while-typing = true

macos-auto-secure-input = true
macos-secure-input-indication = true
macos-titlebar-style = tabs
macos-icon = xray

adjust-cursor-thickness = 2
adjust-cell-height = 5
adjust-cursor-height = 10

window-colorspace = display-p3
window-step-resize = true

window-padding-y = 0
window-padding-balance = true
window-padding-color = extend

unfocused-split-opacity = 0.6

# =========================
# Pane navigation
# =========================
keybind = option+shift+tab=goto_split:left
keybind = option+tab=goto_split:right
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right
#conflicts with nano cut text
keybind = ctrl+k=unbind